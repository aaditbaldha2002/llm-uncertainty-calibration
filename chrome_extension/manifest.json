{
  "manifest_version": 3,
  "name": "QueryMate",
  "version": "1.0",
  "description": "LLM Hallucination Checker - Evaluate the reliability of AI-generated answers.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}